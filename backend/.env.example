# 数据库配置
DATABASE_URL="mysql://root:password@localhost:3306/blog_db"

# JWT 密钥
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=3001
NODE_ENV="development"

# 前端 URL (用于 CORS)
FRONTEND_URL="http://localhost:3000"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# API 配置
API_PREFIX="/api/v1"
